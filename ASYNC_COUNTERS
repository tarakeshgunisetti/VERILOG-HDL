module async_up(input clk,reset,up_down,output reg [2:0]q);
  wire s,d;
   
  assign {s,d}=up_down?{~q[0],~q[1]}:{q[0],q[1]};
  always @(posedge clk or posedge reset)
    begin
    if(reset)
      q[0]<=0;
  	else
      q[0]<=~q[0];
    end
  
  always @(posedge s or posedge reset)
    begin
    if(reset)
      q[1]<=0;
  	else
      q[1]<=~q[1];
    end
  
    
  always @(posedge d or posedge reset)
    begin
    if(reset)
      q[2]<=0;
  	else
      q[2]<=~q[2];
    end
endmodule


