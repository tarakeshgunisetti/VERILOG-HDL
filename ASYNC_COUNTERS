module tb;

    reg clk, reset, up_down;
    wire [2:0] q;

    async_up dut (
        .clk(clk),
        .reset(reset),
        .up_down(up_down),
        .q(q)
    );

    // Clock generation
    always #5 clk = ~clk;

    initial begin
        $dumpfile("dump.vcd");
        $dumpvars(0, tb);

        clk = 0;
        reset = 1;
        up_down = 0;   // Up counting

        // Apply reset
      @(posedge clk);
        reset = 0;

        // Count UP for 8 clock cycles
      repeat (9) @(posedge clk);

        // Change direction
        up_down = 1;

        // Count DOWN for 8 clock cycles
        repeat (8) @(posedge clk);

     
        $finish;
    end

    initial begin
        $display("Time\tup_down\tq");
        $monitor("%0t\t%b\t\t%0d", $time, up_down, q);
    end

endmodule
