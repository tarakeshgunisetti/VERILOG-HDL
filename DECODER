module decoder(input [1:0] in,output reg [3:0] out);
  always @(*)
    begin
      case(in)
        2'b00:out=4'd1;
        2'b01:out=4'd2;
        2'b10:out=4'd4;
        2'b11:out=4'd8;
        default:out=4'b0;
      endcase
    end
endmodule


