module tb;
 
  wire [3:0] y;
  reg [1:0] in;
  
  decoder dut(in,y);
  integer i;
  initial begin
    $monitor("time=%0t in=%b y=%b",$time,in,y);
    
    for (i=0;i<=3;i=i+1)
      begin
        in=i;
        #1;
      end
    $finish;
  end
endmodule
    
    
    

